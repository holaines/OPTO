{
  "title": "Micro-Mic Telemetry",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "50ms",
  "time": {
    "from": "now-1m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Audio Signals (ADC Voltages)",
      "gridPos": { "h": 12, "w": 18, "x": 0, "y": 0 },
      "targets": [
        { "expr": "micro_mic_voltage", "legendFormat": "Channel {{channel}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" },
          "unit": "volt",
          "min": 0,
          "max": 3.4
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "gauge",
      "title": "Clock Frequency",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "micro_mic_clock_hz", "legendFormat": "Clock" }],
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "min": 0,
          "max": 3000000,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2000000 },
              { "color": "green", "value": 2150000 },
              { "color": "yellow", "value": 2250000 },
              { "color": "red", "value": 2400000 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Status Flags",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "targets": [
        { "expr": "micro_mic_link_up", "legendFormat": "Link Up" },
        { "expr": "micro_mic_digital", "legendFormat": "Digital" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "LOW/DOWN", "color": "red" },
                "1": { "text": "HIGH/UP", "color": "green" }
              }
            }
          ]
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Telemetry Packet Rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(micro_mic_telemetry_packets_total[5s])",
          "legendFormat": "Packets/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "unit": "pps",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "min": 0
        }
      }
    }
  ]
}
